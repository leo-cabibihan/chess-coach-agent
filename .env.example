OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m3
OPENROUTER_TIMEOUT_SECONDS=12
LOGFIRE_TOKEN=
STOCKFISH_PATH=/opt/homebrew/bin/stockfish
STOCKFISH_DEPTH=9
MONITORING_LOG_PATH=backend/data/logs/events.jsonl
DATABASE_URL=sqlite:///backend/data/chess_coach.db
ENABLE_LOCAL_EMBEDDINGS=false
# Leave blank to use the retrieval benchmark's checked-in production selection.
RETRIEVAL_STRATEGY=
# Override these when using a model whose rates are not built into the app.
OPENROUTER_INPUT_COST_PER_MILLION=0.30
OPENROUTER_OUTPUT_COST_PER_MILLION=1.20
